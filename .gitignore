# Root .gitignore for Expense Tracker System

# 🔐 Secrets & Credentials
.env
.env.*
serviceAccountKey.json
serviceAccount.json
firebase-service-account.json

# 📦 Dependencies
node_modules/
venv/
env/
.venv/
__pycache__/

# ⚡ Build & Output
dist/
.vite/
*.py[cod]
*.pyo
*.pyd

# 🧠 Editor & OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# 📄 Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# 🧪 Misc
*.tmp
*.bak
*.old
.vercel
